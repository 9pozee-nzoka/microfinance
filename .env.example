# ⚠️  TEMPLATE ONLY — DO NOT COMMIT REAL SECRETS
# Copy this file to `.env` (or `.env.production`) and replace the placeholder values.
# The structure below matches the production environment.

APP_NAME="Mweela Cash Capital"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://mweelacredit.co.ke

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mweelacr_mweelacredit
DB_USERNAME=mweelacr_pauljohns730
DB_PASSWORD=YOUR_DB_PASSWORD
DB_PERSISTENT=false

# ── Session / Cache / Queue ───────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.mweelacredit.co.ke
MAIL_PORT=587
MAIL_USERNAME=noreply@mweelacredit.co.ke
MAIL_PASSWORD=YOUR_MAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@mweelacredit.co.ke
MAIL_FROM_NAME="Mweela Cash Capital"

# ── AWS (optional) ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="Mweela Cash Capital"

# ── Performance note ──────────────────────────────────────────
# If public pages are slow and you do NOT have Redis, change the
# following on the live server only (not in this template):
#   SESSION_DRIVER=file
#   CACHE_STORE=file
#   LOG_LEVEL=warning
# Then run:
#   php artisan config:cache && php artisan route:cache && php artisan view:cache && php artisan optimize
